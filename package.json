{
  "name": "safe-keep",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "i": "pnpm install",
    "dev": "pnpm vite",
    "ts:check": "pnpm vue-tsc --noEmit --skipLibCheck",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "pnpm vite build",
    "type-check": "pnpm vue-tsc --build",
    "npm:check": "pnpx npm-check-updates -u",
    "clean": "pnpx rimraf node_modules",
    "clean:cache": "pnpx rimraf node_modules/.cache",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache \"src/**/*.{js,ts,tsx,vue,html}\"",
    "lint:style": "stylelint --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:lint-staged": "lint-staged -c ./.husky/lintstagedrc.ts",
    "format": "prettier --write --experimental-cli --log-level warn \"src/**/*.{js,ts,json,tsx,css,less,vue,html,md}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "date-fns": "^4.1.0",
    "element-plus": "^2.13.0",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tauri-apps/cli": "^2.11.4",
    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vitest/eslint-plugin": "^1.6.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.35.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "~10.6.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.35.0",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.7.4",
    "rollup-plugin-visualizer": "^7.0.0",
    "sass": "^1.97.3",
    "stylelint": "^17.3.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "unocss": "^66.6.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.1.5",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-eslint2": "^5.0.5",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-style-import": "^2.0.0",
    "vite-plugin-url-copy": "^1.1.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1"
  }
}
