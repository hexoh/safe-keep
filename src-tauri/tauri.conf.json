{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "safe-keep",
  "version": "0.1.0",
  "identifier": "com.safekeep.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Safe Keep",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "hardenedRuntime": true
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "YOUR_UPDATER_SIGNATURE_PUBKEY_HERE",
      "endpoints": ["https://github.com/hexoh/safe-keep/releases/latest/download/update.json"],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
